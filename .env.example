# AI Provider Connection Configuration
# Corvus uses the standard OpenAI client SDK.
# You can connect it to the official OpenAI API or any OpenAI-compatible provider (e.g. NVIDIA NIM, DeepSeek, local Ollama).

# The base endpoint URL for the AI service. 
# For official OpenAI, leave blank or use: https://api.openai.com/v1
# For NVIDIA NIM API, use: https://integrate.api.nvidia.com/v1
AI_API_URL=https://integrate.api.nvidia.com/v1

# The secret API token/key for authenticating with the AI provider.
AI_API_TOKEN=your-api-token-here

# The exact model identifier to request.
# Examples: "gpt-4o", "meta/llama-3.1-70b-instruct", "minimaxai/minimax-m2.7"
AI_API_MODEL=meta/llama-3.1-70b-instruct

# To prevent overloading LLM context limits on long surveys, 
# questions are processed in sequential chunks of this size.
AI_CHUNK_SIZE=30

# Path to the active markdown persona description file.
PERSONA_FILE=persona/persona-example.md

# The target public Google Form URL to parse, answer, and submit.
FORM_URL=https://docs.google.com/forms/d/e/1FAIpQLSduMasdasdp4-F6vsc4I7PkgR3Q8mO1FL6QBTh9dkiaDywbw/viewform
